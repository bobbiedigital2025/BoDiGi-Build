# ============================================================
# BoDiGi-Build — Environment Variable Template
# Copy this file to frontend/.env and backend/.env and fill in
# your actual values. Never commit real secrets to source control.
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Frontend URL (set to your Netlify URL in production) ────
FRONTEND_URL=http://localhost:5173

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── App secrets ──────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret
MCP_SECRET=change-me-to-a-random-secret

# ── AI / Agent ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...
VITE_API_URL=http://localhost:4000
